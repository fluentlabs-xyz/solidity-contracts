# ============================================================================
# Deploy Script Configuration
# Copy to .env and fill in values. See docs/DeveloperGuide.md for full documentation.
# ============================================================================

# ─── Required: deploy.sh orchestrator ─────────────────────────────────────────

# Named-chain RPC endpoints. `scripts/run-chain.sh` selects the right one from CHAIN.
MAINNET_RPC=https://ethereum-rpc.publicnode.com
FLUENT_MAINNET_RPC=https://rpc.fluent.xyz
L1_TESTNET_RPC=https://ethereum-sepolia-rpc.publicnode.com
FLUENT_TESTNET_RPC_URL=https://rpc.testnet.fluent.xyz

# Legacy aliases used by older helper scripts.
L1_RPC=https://ethereum-sepolia-rpc.publicnode.com
L2_RPC=https://rpc.testnet.fluent.xyz

# Deployer account name (created via: cast wallet import deployer --interactive)
DEPLOYER=deployer

# Foundry output directory (default: "out", only set if foundry.toml overrides it)
# FOUNDRY_OUT=out

# ─── Optional: deploy.sh orchestrator ─────────────────────────────────────────

# Preferred release target. This derives RPC + config + manifest via scripts/run-chain.sh.
# Supported: L1_MAINNET, L2_MAINNET, L1_TESTNET, L2_TESTNET, LOCAL_L1, LOCAL_L2
CHAIN=L2_TESTNET

# Legacy deployment environment for older scripts. Prefer CHAIN for migrations/releases.
ENV=testnet

# Set to 1 to verify contracts on block explorers after deployment
VERIFY=0

# Etherscan API key (required when VERIFY=1)
ETHERSCAN_API_KEY=

# ─── Optional: role overrides (override values from config JSON) ──────────────

# INITIAL_OWNER=0x...
# ADMIN_ROLE=0x...
# PAUSER_ROLE=0x...
# RELAYER_ROLE=0x...

# ─── Optional: rollup parameter overrides ─────────────────────────────────────

# SP1_VERIFIER=0x397A5f7f3dBd538f23DE225B51f532c34448dA9B
# ROLLUP_SEQUENCER=0x...
# ROLLUP_CHALLENGER=0x...
# ROLLUP_PROVER=0x...
# ROLLUP_EMERGENCY=0x...
# ROLLUP_PRECONFIRMATION_ROLE=0x...
# ROLLUP_PROGRAM_VKEY=0x...
# ROLLUP_GENESIS_HASH=0x...
# ROLLUP_SUBMIT_BLOBS_WINDOW=7200
# ROLLUP_PRECONFIRM_WINDOW=7201
# ROLLUP_CHALLENGE_WINDOW=10800
# ROLLUP_FINALIZATION_DELAY=14400
# ROLLUP_CHALLENGE_DEPOSIT_AMOUNT=10000000000000000
# ROLLUP_INCENTIVE_FEE=1000000000000000
# ROLLUP_ACCEPT_DEPOSIT_DEADLINE=10000

# ─── Optional: output paths ──────────────────────────────────────────────────

# OUTPUT_PATH=deployments/testnet/l1.json

# ─── Optional: unsafe upgrades (only needed for first upgrade without reference build) ─

# ALLOW_UNSAFE_UPGRADES=true

# ─── Component scripts: required env vars (for standalone/emergency use) ──────
# These are NOT needed when using deploy.sh — the orchestrator handles them.

# DeployL1Bridge / DeployL2Bridge
# ROLLUP=0x...                    (L1 bridge: rollup address, or 0x0 if not yet deployed)
# L1_BLOCK_ORACLE=0x...           (L2 bridge: oracle address)
# RECEIVE_MSG_DEADLINE=100        (L1 bridge: must be non-zero — frozen into outbound L1->L2 messages at send time)
# DEPOSIT_PROCESSING_WINDOW=10000 (L1 bridge: must be non-zero — max L1 blocks the rollup is allowed to consume a sent message before being considered corrupted)

# DeployRollup (standalone)
# ROLLUP_BRIDGE=0x...         (bridge address — required)
# ROLLUP_NITRO_VERIFIER=0x... (verifier address — required)

# DeployERC20Gateway / DeployNativeGateway
# BRIDGE_ADDRESS=0x...
# FACTORY_ADDRESS=0x...       (ERC20Gateway only)

# DeployNitroVerifier
# ATTESTATION_VERIFIER=0x...  (SP1 verifier contract)
# ADMIN=0x...

# DeployL1BlockOracle
# SUBMITTER=0x...             (hot key for block number updates)

# ─── Upgrade scripts ─────────────────────────────────────────────────────────

# PROXY_ADDRESS=0x...         (target proxy to upgrade)

# ─── Timelock + governance ──────────────────────────────────────────────────

# SAFE_ADDRESS=0x...          (Gnosis Safe multisig — proposer/executor for timelocks)
# NORMAL_TIMELOCK=0x...       (normal timelock address — for MigrateRoles)
# EMERGENCY_TIMELOCK=0x...    (emergency timelock address — for MigrateRoles)
# NORMAL_DELAY=86400          (24h for mainnet, 60 for testnet)
# EMERGENCY_DELAY=60          (1min for mainnet, 10 for testnet)
# LAYER=l1                    (l1 or l2 — for MigrateRoles)
