# ============================================================================
# Deploy Script Configuration
# Copy to .env and fill in values. See DEPLOY.md for full documentation.
# ============================================================================

# ─── Required: deploy.sh orchestrator ─────────────────────────────────────────

# RPC endpoints
L1_RPC=https://ethereum-sepolia-rpc.publicnode.com
L2_RPC=https://rpc.testnet.fluent.xyz

# Deployer account name (created via: cast wallet import deployer --interactive)
DEPLOYER=deployer

# Foundry output directory (must match foundry.toml `out` setting)
FOUNDRY_OUT=forge-out

# ─── Optional: deploy.sh orchestrator ─────────────────────────────────────────

# Config environment (default: testnet). Maps to scripts/config/<NETWORK_L1>.json
NETWORK_L1=testnet/l1
NETWORK_L2=testnet/l2

# Set to 1 to verify contracts on block explorers after deployment
VERIFY=0

# Etherscan API key (required when VERIFY=1)
ETHERSCAN_API_KEY=

# ─── Optional: role overrides (override values from config JSON) ──────────────

# INITIAL_OWNER=0x...
# ADMIN_ROLE=0x...
# PAUSER_ROLE=0x...
# RELAYER_ROLE=0x...

# ─── Optional: rollup parameter overrides ─────────────────────────────────────

# SP1_VERIFIER=0x397A5f7f3dBd538f23DE225B51f532c34448dA9B
# ROLLUP_SEQUENCER=0x...
# ROLLUP_CHALLENGER=0x...
# ROLLUP_PROVER=0x...
# ROLLUP_EMERGENCY=0x...
# ROLLUP_PRECONFIRMATION_ROLE=0x...
# ROLLUP_PROGRAM_VKEY=0x...
# ROLLUP_GENESIS_HASH=0x...
# ROLLUP_SUBMIT_BLOBS_WINDOW=7200
# ROLLUP_PRECONFIRM_WINDOW=7201
# ROLLUP_CHALLENGE_WINDOW=10800
# ROLLUP_FINALIZATION_DELAY=14400
# ROLLUP_CHALLENGE_DEPOSIT_AMOUNT=10000000000000000
# ROLLUP_INCENTIVE_FEE=1000000000000000
# ROLLUP_ACCEPT_DEPOSIT_DEADLINE=10000

# ─── Optional: output paths ──────────────────────────────────────────────────

# OUTPUT_PATH=deployments/sepolia.json

# ─── Required for L2 deployment (UniversalTokenFactory has unlinked libs) ─────

ALLOW_UNSAFE_UPGRADES=true

# ─── Component scripts: required env vars (for standalone/emergency use) ──────
# These are NOT needed when using deploy.sh — the orchestrator handles them.

# DeployL1Bridge / DeployL2Bridge
# ROLLUP=0x...               (L1 bridge: rollup address, or 0x0 if not yet deployed)
# L1_BLOCK_ORACLE=0x...      (L2 bridge: oracle address)
# RECEIVE_MSG_DEADLINE=100    (L2 bridge: must be non-zero)

# DeployRollup (standalone)
# ROLLUP_BRIDGE=0x...         (bridge address — required)
# ROLLUP_NITRO_VERIFIER=0x... (verifier address — required)

# DeployERC20Gateway / DeployNativeGateway
# BRIDGE_ADDRESS=0x...
# FACTORY_ADDRESS=0x...       (ERC20Gateway only)

# DeployNitroVerifier
# ATTESTATION_VERIFIER=0x...  (SP1 verifier contract)
# ADMIN=0x...

# DeployL1BlockOracle
# SUBMITTER=0x...             (hot key for block number updates)

# ─── Upgrade scripts ─────────────────────────────────────────────────────────

# PROXY_ADDRESS=0x...         (target proxy to upgrade)
