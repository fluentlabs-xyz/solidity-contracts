{
    "name": "bridge_contracts",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "test": "npx hardhat test",
        "test:fluent-dev": "HARDHAT_NETWORK=fluent-dev npx hardhat test test/UniversalTokenFactory.test.js",
        "test:fluent-fork": "HARDHAT_NETWORK=anvil-fluent-fork npx hardhat test test/UniversalTokenFactory.test.js",
        "anvil:fluent": "anvil --fork-url https://rpc.dev.fluent.xyz/",
        "deploy:fluent-factory": "npx hardhat run scripts/DeployUniversalTokenFactory.js --network fluent-dev",
        "deploy:fluent-local": "npx hardhat run scripts/DeployUniversalTokenFactory.js --network fluent-local",
        "deploy:bridges-no-rollup": "npx hardhat run scripts/DeployBridgesNoRollup.js",
        "relay:no-rollup": "node relay/RelayNoRollup.js",
        "send-eth:local": "npx hardhat run scripts/SendEth.js --network fluent-local",
        "print:deployment-data": "npx hardhat run scripts/PrintDeploymentData.js",
        "build": "npx hardhat compile",
        "format:js": "prettier --write 'test/**/*.js' 'scripts/**/*.js'",
        "format:check": "prettier --check 'contracts/**/*.sol' 'test/**/*.js' 'scripts/**/*.js'",
        "solhint": "./node_modules/.bin/solhint -f table contracts/**/*.sol"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@nomicfoundation/hardhat-ethers": "^3.0.6",
        "@nomicfoundation/hardhat-ignition": "^0.15.4",
        "@nomicfoundation/hardhat-ignition-ethers": "^0.15.4",
        "@nomicfoundation/hardhat-toolbox": "^2.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.8",
        "@nomicfoundation/ignition-core": "^0.15.4",
        "@nomiclabs/hardhat-ethers": "^2.2.3",
        "@nomiclabs/hardhat-solhint": "^3.0.1",
        "@openzeppelin/hardhat-upgrades": "^3.0.0",
        "c-kzg": "^4.1.0",
        "chai": "4",
        "ethers": "^6.12.2",
        "hardhat": "^2.19.2",
        "hardhat-abi-exporter": "^2.10.1",
        "mocha": "^11.7.5",
        "prettier": "^3.1.1",
        "prettier-plugin-solidity": "^1.2.0",
        "solhint": "^4.0.0"
    },
    "dependencies": {
        "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
        "@openzeppelin/contracts": "^5.3.0",
        "@openzeppelin/contracts-upgradeable": "^5.3.0",
        "dotenv": "^17.3.1",
        "keccak256": "^1.0.6",
        "merkletreejs": "^0.5.2",
        "solc": "^0.8.23-fixed"
    },
    "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
